# SonicBloom Environment Configuration
# Copy this file to .env and fill in your values

# Backend
GROQ_API_KEY=your_groq_api_key_here
DATABASE_URL=postgresql://user:password@localhost:5432/sonicbloom
REDIS_URL=redis://localhost:6379
SECRET_KEY=your-super-secret-key-change-this-in-production
RUNPOD_API_KEY=your_runpod_api_key_here

# MusicGen Settings
MUSICGEN_MODEL_SIZE=small  # small, medium, large
MUSICGEN_DEVICE=cuda  # cuda or cpu

# Mobile
API_URL=http://localhost:8000
# For production: https://api.sonicbloom.ai

# AWS S3 (for audio file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=sonicbloom-audio
AWS_REGION=us-east-1

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SendGrid (for emails)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@sonicbloom.ai

# Monitoring
SENTRY_DSN=
DATADOG_API_KEY=

# Feature Flags
ENABLE_PREMIUM=true
ENABLE_OFFLINE_MODE=false
MAX_TRACK_DURATION=600  # 10 minutes
